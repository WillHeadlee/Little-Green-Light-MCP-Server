        "description": "Retrieve all constituents with pagination.",
        "operationId": "listConstituents",
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "description": "Maximum records to return",
            "required": false,
            "type": "integer",
            "default": 50
          },
          {
            "name": "offset",
            "in": "query",
            "description": "Number of records to skip",
            "required": false,
            "type": "integer",
            "default": 0
          }
        ],
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      },
      "post": {
        "summary": "Create Constituent",
        "description": "Create a new constituent record.",
        "operationId": "createConstituent",
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "first_name": { "type": "string" },
                "last_name": { "type": "string" },
                "organization_name": { "type": "string" },
                "constituent_type": { "type": "string", "enum": ["individual", "organization"], "default": "individual" }
              }
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Created"
          }
        }
      }
    },
