  },
  "host": "api.littlegreenlight.com",
  "basePath": "/api/v1",
  "schemes": [
    "https"
  ],
  "securityDefinitions": {
    "api_key": {
      "type": "apiKey",
      "name": "access_token",
      "in": "query",
      "description": "Enter your raw Little Green Light API Key generated in Settings > Integration > API Keys."
    }
  },
  "security": [
    {
      "api_key": []
    }
  ],
